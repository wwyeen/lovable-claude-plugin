{
  "name": "lovable-claude-plugin",
  "version": "1.0.0",
  "description": "lovable.dev-style Claude Code environment — shareable plugin",
  "type": "module",
  "bin": {
    "lovable-claude-plugin": "./dist/install.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "npm run build",
    "install:global": "node dist/install.js --global",
    "install:project": "node dist/install.js --project",
    "uninstall:global": "node dist/install.js --uninstall --global --force",
    "uninstall:project": "node dist/install.js --uninstall --project --force"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    ".claude",
    "CLAUDE.md",
    "dist",
    "README.md",
    "templates"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "keywords": ["claude-code", "lovable", "plugin", "shadcn", "supabase"],
  "license": "MIT"
}
