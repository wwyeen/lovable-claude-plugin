{
  "name": "lovable-claude-plugin",
  "version": "1.0.0",
  "description": "lovable.dev-style Claude Code environment — shareable plugin",
  "type": "module",
  "bin": {
    "lovable-claude-plugin": "./install.js"
  },
  "scripts": {
    "install:global": "node install.js --global",
    "install:project": "node install.js --project",
    "uninstall:global": "node install.js --uninstall --global --force",
    "uninstall:project": "node install.js --uninstall --project --force"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    ".claude",
    ".github",
    "CLAUDE.md",
    "install.js",
    "README.md"
  ],
  "keywords": ["claude-code", "lovable", "plugin", "shadcn", "supabase"],
  "license": "MIT"
}
